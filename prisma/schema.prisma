// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth.js Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  USER
  ADMIN
}

// Language Model
model Language {
  id        String   @id @default(cuid())
  code      String   @unique // tr, en, de, fr, etc.
  name      String // Türkçe, English, Deutsch, Français
  flag      String // Country code for flag (TR, US, DE, FR)
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  pages      PageContent[]
  PageModule PageModule[]
}

// Global Page - Sayfa yapısı ve hiyerarşi
model GlobalPage {
  id         String   @id @default(cuid())
  slug       String   @unique
  parentId   String?
  order      Int      @default(0)
  isActive   Boolean  @default(true)
  isHomePage Boolean  @default(false) // Ana sayfa işaretleyicisi
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  parent   GlobalPage?   @relation("GlobalPageHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children GlobalPage[]  @relation("GlobalPageHierarchy")
  contents PageContent[]
  modules  PageModule[]

  @@index([parentId, order])
}

// Page Content - Dil bazında içerik
model PageContent {
  id             String   @id @default(cuid())
  globalPageId   String
  languageId     String
  title          String
  description    String?
  slug           String // Dile özel slug
  seoTitle       String?
  seoDescription String?
  content        String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  globalPage GlobalPage   @relation(fields: [globalPageId], references: [id], onDelete: Cascade)
  language   Language     @relation(fields: [languageId], references: [id], onDelete: Cascade)
  modules    PageModule[]

  @@unique([globalPageId, languageId])
  @@unique([slug, languageId]) // Dil bazında unique slug
  @@index([globalPageId])
  @@index([languageId])
  @@index([slug])
}

// Page Module - Dil bazında modüller
model PageModule {
  id            String   @id @default(cuid())
  pageContentId String
  languageId    String
  type          String
  content       Json
  order         Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  pageContent  PageContent @relation(fields: [pageContentId], references: [id], onDelete: Cascade)
  language     Language    @relation(fields: [languageId], references: [id], onDelete: Cascade)
  GlobalPage   GlobalPage? @relation(fields: [globalPageId], references: [id])
  globalPageId String?

  @@index([pageContentId, order])
  @@index([languageId])
}

// Eski Page modeli - Migration için geçici olarak tutuyoruz
model Page {
  id             String   @id @default(cuid())
  title          String
  description    String?
  slug           String
  seoTitle       String?
  seoDescription String?
  parentId       String?
  languageId     String
  order          Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([slug, languageId])
  @@index([languageId])
  @@index([parentId])
  @@map("page_old")
}

model GlobalDesign {
  id        String  @id @default(cuid())
  customCss String?
  customJs  String?

  // Font Settings
  titleFontSize   String? @default("36px")
  titleFontWeight String? @default("600")
  titlePadding    String? @default("40px 0px")

  paragraphFontSize   String? @default("14px")
  paragraphFontWeight String? @default("300")
  paragraphLineHeight String?

  buttonFontSize   String? @default("14px")
  buttonFontWeight String? @default("400")
  buttonWidth      String? @default("140px")

  imageRadius String?

  menuFont      String? @default("Poppins")
  titleFont     String?
  paragraphFont String?

  // Color Settings
  siteBackgroundColor String?
  titleColor          String?
  paragraphColor      String?
  hoverColor          String?

  menuBackgroundColor String?
  menuTextColor       String?

  footerBackgroundColor String?
  footerTextColor       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GlobalLogos {
  id          String   @id @default(cuid())
  logo        String? // Ana logo
  footerLogo  String? // Footer logo
  favicon     String? // Favicon
  placeholder String? // Image placeholder
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
